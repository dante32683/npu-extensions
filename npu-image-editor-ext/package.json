{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "npu-image-editor",
  "title": "NPU Image Editor",
  "description": "High-performance image editing using Windows Copilot Runtime and NPU.",
  "icon": "extension-icon.png",
  "author": "user",
  "license": "MIT",
  "commands": [
    {
      "name": "modify-image",
      "title": "Modify Image (NPU)",
      "description": "NPU-powered image editing.",
      "mode": "view"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.71.0",
    "jimp": "^1.6.1"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^1.0.8",
    "@types/node": "20.8.10",
    "@types/react": "19.0.10",
    "eslint": "^8.51.0",
    "prettier": "^3.0.3",
    "typescript": "^5.2.2"
  },
  "scripts": {
    "build": "ray build -e dist",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "publish": "npx @raycast/api@latest publish"
  }
}
